{
  "name": "sensordata-forwarder",
  "version": "0.1.0",
  "description": "A Bun-based sensor data forwarding pipeline for e生态 OpenAPI.",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts -- --pipeline-config ./config/example.config.json",
    "start": "bun run src/index.ts",
    "check": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "mqtt": "^5.15.0",
    "zod": "^4.3.6"
  }
}
