{
  "api": {
    "baseUrl": "http://openapi.ecois.info",
    "appid": "replace-with-your-appid",
    "secret": "replace-with-your-secret",
    "timeoutMs": 15000,
    "retry": {
      "attempts": 3,
      "backoffMs": 500
    }
  },
  "devices": {
    "pageSize": 100,
    "includeAuthorized": ["own", "shared"],
    "includeSerials": [],
    "excludeSerials": [],
    "concurrency": 4,
    "fetch": {
      "mode": "incremental",
      "includeParameters": [],
      "includeNodes": []
    },
    "overrides": {
      "PLUVIO-SN-EXAMPLE": {
        "mode": "pluviometerHistory",
        "range": "20250101,20251231"
      }
    }
  },
  "converter": {
    "scriptPath": "./scripts/default-converter.ts",
    "exportName": "default"
  },
  "routing": {
    "defaultOutputIds": ["http-primary"]
  },
  "outputs": [
    {
      "id": "http-primary",
      "type": "http",
      "url": "https://example.com/iot/ingest",
      "method": "POST",
      "headers": {
        "x-api-key": "replace-me"
      },
      "timeoutMs": 10000
    },
    {
      "id": "mqtt-primary",
      "type": "mqtt",
      "brokerUrl": "mqtt://broker.example.com:1883",
      "topic": "sensor/ecois/default",
      "clientId": "sensordata-forwarder",
      "qos": 1,
      "retain": false
    }
  ],
  "state": {
    "path": "./data/state.json"
  },
  "logging": {
    "level": "info"
  }
}
